{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "lib": ["ES2023", "DOM"],
    "paths": {
      "@portico/core": ["packages/core/src/index.ts"],
      "@portico/adapters": ["packages/adapters/src/index.ts"],
      "@portico/daemon": ["packages/daemon/src/index.ts"],
      "@portico/client": ["packages/client/src/index.ts"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/tests/**/*.ts",
    "examples/node-cli/**/*.ts"
  ]
}
